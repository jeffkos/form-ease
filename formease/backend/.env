# ⚠️ IMPORTANT: Ce fichier contient des valeurs d'exemple
# Remplacez par vos vraies valeurs pour votre environnement

# Base de données PostgreSQL (CHANGEZ CES VALEURS)
DATABASE_URL="postgresql://username:password@localhost:5432/formease_db?schema=public"

# Clé secrète JWT (GÉNÉREZ UNE NOUVELLE CLÉ)
JWT_SECRET="CHANGE-THIS-TO-A-SECURE-SECRET-KEY-AT-LEAST-32-CHARACTERS"

# Configuration SMTP (REMPLACEZ PAR VOS VALEURS)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-secure-password
SMTP_FROM=noreply@yourdomain.com

# Configuration Prisma
NODE_ENV=development
PRISMA_LOG_LEVEL=info
PRISMA_ENABLE_TRACING=true
PORT=4000
